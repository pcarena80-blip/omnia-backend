# ═══════════════════════════════════════════════════════════════
# OMNIA - Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────────────────
APP_NAME=OMNIA
APP_ENV=development
SECRET_KEY=your-secret-key-change-this-to-random-string
DEBUG=true

# ─── Database ──────────────────────────────────────────────────
# For development, SQLite is used by default (no setup needed)
# For production, switch to PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/omnia
DATABASE_URL=sqlite+aiosqlite:///./omnia.db

# ─── LLM APIs (Choose one or both) ────────────────────────────
# Google Gemini (Free tier: 60 requests/min)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (Pay-per-use, ~$0.01/1K tokens)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Default LLM provider: "gemini" or "openai"
DEFAULT_LLM_PROVIDER=gemini

# ─── Google Cloud APIs ─────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Places API, Calendar API, Geocoding API
GOOGLE_MAPS_API_KEY=
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials/google_calendar.json

# ─── Web Search ────────────────────────────────────────────────
# Tavily (Free: 1000 searches/month)
# Get key: https://tavily.com
TAVILY_API_KEY=

# ─── Voice Services ────────────────────────────────────────────
# ElevenLabs TTS (Free: 10K chars/month)
# Get key: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Communication (Phase 4) ──────────────────────────────────
# Twilio (Free trial: $15 credit)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Business API
# Get from: https://developers.facebook.com/apps
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Redis (Optional for dev, needed for production) ──────────
REDIS_URL=redis://localhost:6379/0

# ─── Security ─────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7
